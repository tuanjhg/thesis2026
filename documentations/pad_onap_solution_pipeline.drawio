          <mxGeometry x="1060" y="570" width="170" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="teardown" value="8. SO Teardown&#xa;Terminate chain and scale down" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#4f4f4f;strokeWidth=1.5;fontFamily=Times New Roman;fontSize=14;fontStyle=1;" vertex="1" parent="1">
