          <mxGeometry x="120" y="350" width="240" height="78" as="geometry"/>
        </mxCell>

        <mxCell id="predict" value="3. M1 Predictor (TCN/LSTM)&#xa;Estimate attack probability p̂(t+Δ)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#4f4f4f;strokeWidth=1.5;fontFamily=Times New Roman;fontSize=14;fontStyle=1;" vertex="1" parent="1">
