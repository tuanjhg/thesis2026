        <mxCell id="mitigate" value="7. Mitigation VNF Chain&#xa;Vol: RateLimiter→Scrubber&#xa;Proto: Stateful FW→IDS&#xa;Slow: DPI→Behavior Analyzer&#xa;App: WAF→RateLimiter" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#4f4f4f;strokeWidth=1.5;fontFamily=Times New Roman;fontSize=13;" vertex="1" parent="1">
