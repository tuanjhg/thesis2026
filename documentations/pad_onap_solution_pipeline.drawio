          <mxGeometry x="500" y="470" width="180" height="64" as="geometry"/>
        </mxCell>
        <mxCell id="classify" value="4. M2 Classifier&#xa;Predict attack class k̂" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#4f4f4f;strokeWidth=1.5;fontFamily=Times New Roman;fontSize=14;fontStyle=1;" vertex="1" parent="1">
