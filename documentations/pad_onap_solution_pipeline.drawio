        <mxCell id="collect" value="1. Traffic Collection&#xa;sFlow / IPFIX / P4 Telemetry" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#4f4f4f;strokeWidth=1.5;fontFamily=Times New Roman;fontSize=14;fontStyle=1;" vertex="1" parent="1">
